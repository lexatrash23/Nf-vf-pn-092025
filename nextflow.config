// Manifest 
manifest {
    name = 'Venomflow'
    author = 'Holford Lab'
    homePage = 'https://github.com/lexatrash23/Nf-vf-pn-092025'
    description = 'Bulk Paired-end RNAseq analysis pipeline for identification of putative venom transcripts.'
    mainScript = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version = '1.0.0'
}

tower.enabled = true
manifest.defaultBranch = 'main'


// CONDA and SINGULARITY // Default Conda
conda.enabled = true
docker.enabled = false
singularity.enabled = false

profiles {
    conda {
        conda.enabled = true
        docker.enabled = false
        singularity.enabled = false
        process.beforeScript = '''
            if [ -f ~/.bashrc ]; then source ~/.bashrc; fi
            if [ -f ~/miniconda3/etc/profile.d/conda.sh ]; then source ~/miniconda3/etc/profile.d/conda.sh; fi
            if [ -f ~/anaconda3/etc/profile.d/conda.sh ]; then source ~/anaconda3/etc/profile.d/conda.sh; fi
            export PATH=$PATH:$CONDA_PREFIX/bin
        '''
    }
    
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        wave.enabled = true 
        conda.enabled = false
        singularity.enabled = false
    }
    
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        wave.enabled = true 
        conda.enabled = false
        docker.enabled = false

    }
    test {
        params.input_csv = "${projectDir}/TestSample/SampleSheet.csv"

    }

}

    

// Settings for Holford Lab BRIDGES CLUSTER
process {
    executor = 'slurm'
    queue = 'RM-shared'

    // Resource limits 
    resourceLimits = [
    cpus: 30,
    time: 8.h
        ]

    //  RSS < 2 GB //All seqkit steps, blastdatabase creation, default for blast and kallisto but may be need to retry depending on size of files
    withLabel: 'process_bare' {
    cpus = { task.attempt > 1 && ((task.exitStatus == 2 || task.exitStatus == 137) || task.exitStatus == 137) ? 5 * task.attempt : 1 } // 1 10 15  
    }

    // RSS < 15 GB //TD2 Transdeocder Signalp DEEPTMHM Interproscan BUSCO
    withLabel: 'process_medium' {
        cpus = { task.attempt > 1 && (task.exitStatus == 2 || task.exitStatus == 137) ? 5 * task.attempt : 6 } // 6 10 15 
    }
    
    // Standard < 25GB //Bowtie
    withLabel: 'process_high' {
        cpus = { task.attempt > 1 && (task.exitStatus == 2 || task.exitStatus == 137) ? 10 * task.attempt : 10 } // 10 20 30  
    }

}


def timestamp = new java.text.SimpleDateFormat("yyyyMMdd-HHmmss").format(new java.util.Date())

report {
    enabled = true
    overwrite = true
    file = "${launchDir}/reports/Venomflow/${timestamp}/report.html"

}

timeline {
    enabled = true
    overwrite = true
    file = "${launchDir}/reports/Venomflow/${timestamp}/timeline.html"
}

trace {
    enabled = true
    overwrite = true
    file = "${launchDir}/reports/Venomflow/${timestamp}/trace.txt"
}

dag {
    enabled = true
    overwrite = true
    file = "${launchDir}/reports/Venomflow/${timestamp}/flowchart.html"
}


params {
    input_csv = "${launchDir}/InputFiles/SampleSheet.csv"
    DeepTMHMM = false  // default to false true
    ORFPrediction = "TD2" // Both, TD or TD2(default)
    toxprot_fasta =  "${launchDir}/InputFiles/ToxProtFasta.fasta"
    nontoxprot_fasta =  "${launchDir}/InputFiles/NonToxProtFasta.fasta"

    //Fallback blast fastas if the user doesnt provide them 
    Fallback_toxin_fasta = "${projectDir}/FastasForBlast/ToxProtFasta.fasta"
    Fallback_nontoxin_fasta = "${projectDir}/FastasForBlast/nonvenom.fasta.zst"

    //Default outputdir is the launchdir
   outdir = "${launchDir}"

}


